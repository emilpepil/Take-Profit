# Take Profit runs ONLY on Monad Testnet (chain ID 10143).
# Copy this file to .env before the deployment step. Never commit .env.

# Public Monad Testnet JSON-RPC endpoint. You may replace it with a private testnet RPC later.
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz

# Private key of a TESTNET-ONLY wallet. Leave empty until deployment is approved.
# Do not use a mainnet wallet or a wallet holding real funds.
DEPLOYER_PRIVATE_KEY=

# Added later, when the keeper is implemented.
KEEPER_PRIVATE_KEY=
KEEPER_POLL_INTERVAL_SECONDS=10

# Separate testnet-only wallet for the Demo Faucet. This wallet sends a small
# pre-funded ERC-20 bundle; it never sends MON and must not reuse the keeper key.
# DEMO_FAUCET_ENABLED=true
# DEMO_FAUCET_PRIVATE_KEY=
# DEMO_FAUCET_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Automatic execution is OFF by default. The first live test can only execute JAMES once.
# Keep these commented out until you explicitly approve a real Monad Testnet transaction.
# AUTO_EXECUTE=true
# AUTO_EXECUTE_CONFIRMATION=MONAD_TESTNET_JAMES_ONCE
# AUTO_EXECUTE_SYMBOL=JAMES
# AUTO_EXECUTE_MAX_GAS=300000

# Optional EOA rule that the keeper may inspect. Tokens remain in the EOA wallet.
# Set these only after deploying the JAMES EOA executor in the UI and creating a rule.
# EOA_JAMES_EXECUTOR=
# EOA_JAMES_EXECUTOR_V2=
# V3 permits up to 100 simultaneously active levels; cancelled and completed levels free a slot.
# EOA_JAMES_EXECUTOR_V3=
# EOA_RULE_OWNER=
# EOA_V3_AUTO_EXECUTE_ALL=true
# EOA_V3_AUTO_EXECUTE_CONFIRMATION=MONAD_TESTNET_JAMES_V3_ALL
# EOA_V3_AUTO_EXECUTE_MAX_GAS=320000
# EOA_V3_AUTO_EXECUTE_ALL_MAX_TOTAL_AMOUNT=45

# Added later, when Telegram notifications are implemented.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Set to true only after both values above are present and you have messaged the bot.
KEEPER_TELEGRAM_ENABLED=false
